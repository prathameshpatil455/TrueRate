PORT=3001
NODE_ENV=development

# DATA_DIR=apps/api/data

JWT_ACCESS_SECRET=change-me-in-production-use-long-random-string
JWT_REFRESH_SECRET=change-me-in-production-use-another-long-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

EXCHANGERATE_API_KEY=your-exchangerate-api-key
ETHERSCAN_API_KEY=your-etherscan-api-key

CORS_ORIGIN=http://localhost:5173

RATE_POLL_INTERVAL_MINUTES=10

# Email (optional — logs to console when unset)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=notifications@truerate.app
